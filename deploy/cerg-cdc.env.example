# ============================================================
# CERG · CDC — variables de entorno
# Copiar a /etc/cerg-cdc/cerg-cdc.env y ajustar. NO comitear el real.
# ============================================================

# --- SCADA (solo lo usa el poller) ---
CDC_SCADA_BASE=https://scadavision.cooprg.net
CDC_SCADA_TIMEOUT=8
CDC_POLL_INTERVAL=5
CDC_POLL_MAX_BACKOFF=60

# --- PostgreSQL ---
# Opción A: URL completa
# CDC_DATABASE_URL=postgresql://cerg:CLAVE@localhost:5432/cerg_cdc
# Opción B: piezas sueltas
CDC_DB_HOST=localhost
CDC_DB_PORT=5432
CDC_DB_NAME=cerg_cdc
CDC_DB_USER=cerg
CDC_DB_PASSWORD=cambiar_esta_clave

CDC_NOTIFY_CHANNEL=cdc_snapshot

# --- Web ---
CDC_TREND_DEFAULT_RANGE=28800     # 8 h
CDC_TREND_MAX_RANGE=604800        # 7 días
CDC_TREND_MAX_POINTS=600
CDC_SSE_KEEPALIVE=20

# --- Monitor de conexiones (detrás del botón de configuración) ---
# Contraseña para ver quién está conectado en tiempo real (GET /api/connections).
# Si se deja vacía, el monitor queda DESACTIVADO (no expone datos).
CDC_MONITOR_PASSWORD=
# Segundos sin refresco tras los cuales una conexión se considera caída.
# CDC_SSE_STALE_SECONDS=60

# --- Logs ---
CDC_LOG_LEVEL=INFO

# --- Locale (para que el servicio maneje bien caracteres no-ASCII) ---
LANG=es_AR.UTF-8
LC_ALL=es_AR.UTF-8
